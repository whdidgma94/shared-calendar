# ============================================================
#  shared-calendar — 환경 변수 템플릿
#  이 파일을 복사하여 실제 값으로 채우세요:
#    cp .env.example .env
#  .env 파일은 절대 버전 관리에 커밋하지 마세요.
# ============================================================

# ── 공통 ────────────────────────────────────────────────────
NODE_ENV=production

# ── 백엔드 서버 ──────────────────────────────────────────────
# 백엔드가 수신할 포트 (기본 3000, docker-compose에서 3000 사용)
PORT=3000

# ── 데이터베이스 ──────────────────────────────────────────────
# 형식: postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB>
# 주의: 강력한 비밀번호를 사용하세요 (특수문자 포함 16자 이상 권장)
DATABASE_URL=postgresql://caluser:CHANGE_ME_STRONG_PASSWORD@localhost:5432/shared_calendar

DB_USER=caluser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=shared_calendar

# ── CORS 허용 오리진 ──────────────────────────────────────────
# 쉼표 구분 (예: https://example.com,https://www.example.com)
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ── 프론트엔드 (빌드 타임 주입) ──────────────────────────────
# Vite 빌드 시 번들에 포함되므로 민감 정보는 절대 넣지 마세요.
VITE_API_BASE_URL=http://localhost:3000

# ── 참고: 이 앱은 JWT를 사용하지 않습니다 ──────────────────────
# 인증은 URL 토큰 기반이며 nanoid(22)로 서버에서 발급됩니다.
# JWT_SECRET 항목은 불필요합니다.

# ── 보안 권고 (배포 전 확인) ────────────────────────────────
# [H-1] DB TLS 인증서 검증: backend/src/db/pool.js의
#        ssl.rejectUnauthorized 를 true로 설정하고
#        관리형 DB CA 인증서 경로를 지정하세요.
# [H-2] CSP unsafe-inline 제거: backend/src/middleware/frameHeaders.js
#        의 임베드 CSP를 최소화하고, 프론트엔드 정적 호스팅 계층에서
#        CSP/X-Frame-Options를 재설정하세요.
