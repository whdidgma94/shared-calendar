# Neon PostgreSQL 연결 문자열 (neon.tech 프로젝트 대시보드에서 복사)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# 서버 포트 (Render는 PORT를 자동 주입)
PORT=4000

# 세션 만료 기간 (일 단위, 기본 90일)
SESSION_EXPIRES_DAYS=90

# 허용할 프론트엔드 Origin (배포 후 실제 URL로 교체)
# CORS_ORIGIN=https://shared-calendar-xxxx.onrender.com

# 노드 환경
NODE_ENV=development
