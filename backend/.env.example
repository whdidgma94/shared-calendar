# 서버 포트 (Railway는 PORT를 자동 주입)
PORT=4000

# SQLite DB 파일 경로
# 로컬: 미지정 시 프로젝트 루트 app.db 사용
# Railway 볼륨 사용 시: /data/app.db
DB_PATH=./app.db

# 세션 만료 기간 (일 단위, 기본 90일)
SESSION_EXPIRES_DAYS=90

# 허용할 프론트엔드 Origin (Railway 배포 후 실제 URL로 교체)
# 미설정 시 전체 허용 (개발 환경)
# CORS_ORIGIN=https://your-app.up.railway.app

# 노드 환경
NODE_ENV=development
