<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- 헤더: 제목 + 새로고침 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@+id/widget_refresh_btn"
            android:text="공유 캘린더"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1e3a5f"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_refresh_btn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:text="↻"
            android:textSize="18sp"
            android:textColor="#888888"
            android:gravity="center"
            android:background="#00000000"/>
    </RelativeLayout>

    <!-- 이벤트 1 -->
    <TextView
        android:id="@+id/event_text_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="불러오는 중..."
        android:textSize="12sp"
        android:textColor="#333333"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- 이벤트 2 -->
    <TextView
        android:id="@+id/event_text_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#333333"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- 이벤트 3 -->
    <TextView
        android:id="@+id/event_text_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#333333"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- 구분선 역할 텍스트 (빈 공간) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""/>

    <!-- 앱 열기 버튼 -->
    <TextView
        android:id="@+id/widget_open_btn"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:text="캘린더 열기"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="#1e3a5f"
        android:gravity="center"/>

</LinearLayout>
